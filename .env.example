# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql://educore:educore@localhost:5432/educore?schema=public

# ── Redis (cache, queues, sessions) ──────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ─────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-too
JWT_ACCESS_TTL=900          # 15 minutes
JWT_REFRESH_TTL=2592000     # 30 days

# ── App ──────────────────────────────────────────────
API_PORT=4000
WEB_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── Storage (S3-compatible: AWS S3 / Cloudflare R2 / Spaces) ──
S3_ENDPOINT=
S3_BUCKET=educore-files
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ── Payments ─────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Messaging ────────────────────────────────────────
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
MSG91_API_KEY=              # SMS / WhatsApp (India)
