# ── Database (Supabase-hosted Postgres) ──────────────
# Get/reset the database password at:
#   https://supabase.com/dashboard/project/haxolsyozpifjjqtwsbh/settings/database
DATABASE_URL=postgresql://postgres:[YOUR-DB-PASSWORD]@db.haxolsyozpifjjqtwsbh.supabase.co:5432/postgres

# ── Redis (cache, queues, sessions) ──────────────────
REDIS_URL=redis://localhost:6379

# ── Supabase Auth (server-side — never expose SECRET_KEY to the browser) ──
SUPABASE_URL=https://haxolsyozpifjjqtwsbh.supabase.co
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=https://haxolsyozpifjjqtwsbh.supabase.co/auth/v1/.well-known/jwks.json

# ── App ──────────────────────────────────────────────
API_PORT=4000
WEB_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── Supabase Auth (frontend — apps/web/.env.local, publishable key is safe to expose) ──
NEXT_PUBLIC_SUPABASE_URL=https://haxolsyozpifjjqtwsbh.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ── Storage (S3-compatible: AWS S3 / Cloudflare R2 / Spaces) ──
S3_ENDPOINT=
S3_BUCKET=educore-files
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ── Payments ─────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Messaging ────────────────────────────────────────
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
MSG91_API_KEY=              # SMS / WhatsApp (India)
